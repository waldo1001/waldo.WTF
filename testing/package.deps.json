    "test:integration": "vitest run src/**/__integration__",
    "test:contract": "vitest run src/**/__contract__",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
