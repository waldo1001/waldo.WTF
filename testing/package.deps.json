{
  "_comment": "Merge these blocks into the project's package.json at Weekend 2. Versions are intentionally loose (caret ranges) — tighten when the project is first built and lockfile is created.",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
