#!/usr/bin/env bash
# Push WhatsApp exports from the Mac to the NAS inbox bind mount. The running
# container has a chokidar watcher on the inbox folder — it picks up each file
# within ~500ms of the scp landing, imports, and archives. No further action.
#
# Configurable via env:
#   WTF_WHATSAPP_SRC   source dir on the Mac        (default: ~/Downloads)
#   WTF_WHATSAPP_TRASH mac-side archive after push  (default: ~/WhatsAppArchive)
#   WTF_NAS_HOST       ssh host for the NAS         (default: waldonas3)
#   WTF_NAS_INBOX      inbox path on the NAS        (default: /volume1/docker/waldo-wtf/whatsapp-inbox)

set -euo pipefail

SRC_DIR="${WTF_WHATSAPP_SRC:-$HOME/Downloads}"
TRASH_DIR="${WTF_WHATSAPP_TRASH:-$HOME/WhatsAppArchive}"
SSH_HOST="${WTF_NAS_HOST:-waldonas3}"
INBOX="${WTF_NAS_INBOX:-/volume1/docker/waldo-wtf/whatsapp-inbox}"

shopt -s nullglob
files=("$SRC_DIR"/WhatsApp\ Chat\ *.txt "$SRC_DIR"/WhatsApp\ Chat\ *.zip)
if (( ${#files[@]} == 0 )); then
  echo "No WhatsApp exports found in $SRC_DIR"
  exit 0
fi

echo "Found ${#files[@]} file(s):"
for f in "${files[@]}"; do echo "  $(basename "$f")"; done

echo
echo "→ scp to $SSH_HOST:$INBOX/"
scp "${files[@]}" "$SSH_HOST:$INBOX/"

ym="$(date -u +%Y-%m)"
dest="$TRASH_DIR/$ym"
mkdir -p "$dest"
echo
echo "→ moving local copies to $dest/"
for f in "${files[@]}"; do
  name="$(basename "$f")"
  target="$dest/$name"
  n=0
  while [[ -e "$target" ]]; do
    n=$((n + 1))
    stem="${name%.*}"
    ext="${name##*.}"
    target="$dest/$stem-$n.$ext"
  done
  mv -- "$f" "$target"
done

echo
echo "Done."
