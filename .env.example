# waldo.WTF — environment template. Copy to .env and fill in. Never commit .env.

# Required: Microsoft Entra app (multitenant) client ID used by MSAL device code flow.
MS_CLIENT_ID=

# Required: bearer token used to authenticate clients to the local MCP HTTP server.
# Generate with: openssl rand -hex 32
BEARER_TOKEN=

# Optional: path to the SQLite lake. Defaults to ./data/lake.db
# WALDO_DB_PATH=

# Optional: directory holding MSAL token cache + delta state. Defaults to ./data/auth
# WALDO_AUTH_DIR=

# Optional: local port the MCP HTTP server binds to. Defaults to 8765.
# WALDO_PORT=

# Optional: host/interface the MCP HTTP server binds to. Defaults to 127.0.0.1
# (loopback only — safe for local dev). Set to 0.0.0.0 ONLY when running inside
# a container so the port can be published to the host. Do NOT set this on a
# bare-metal install unless you understand the exposure.
# WALDO_BIND_HOST=

# Optional: sync loop interval in milliseconds. Defaults to 300000 (5 minutes).
# WALDO_SYNC_INTERVAL_MS=

# Optional: cap the INITIAL delta backfill window to the last N days. Positive
# integer, no default (unset = pull entire history on first sync). Only applies
# to the first delta call per (account, source); once a deltaLink is stored,
# subsequent calls remain incremental and this value is ignored. To apply a new
# window to an already-synced account, wipe WALDO_DB_PATH + WALDO_AUTH_DIR and
# re-login — existing rows are NOT pruned.
# WALDO_BACKFILL_DAYS=30

# Optional: WhatsApp `.txt` export importer (Weekend 6+).
# Set WALDO_WHATSAPP_WATCH=true to start a chokidar watcher in the main process
# that picks up `WhatsApp Chat*.txt` or `WhatsApp Chat*.zip` files (iOS
# exports as .zip) dropped into the downloads path,
# imports them into the lake under source='whatsapp', and moves the original
# into the archive path under YYYY-MM/. Leave unset to disable the watcher;
# you can still run `npm run dev -- --import-whatsapp` for a one-shot backfill.
# WALDO_WHATSAPP_WATCH=true
# WALDO_WHATSAPP_DOWNLOADS_PATH=/Users/you/Downloads
# WALDO_WHATSAPP_ARCHIVE_PATH=/Users/you/WhatsAppArchive
# WALDO_WHATSAPP_ACCOUNT=whatsapp-local

# Optional: OAuth 2.1 surface for the MCP endpoint (slice 1+: discovery + DCR).
# When set, /.well-known/oauth-authorization-server,
# /.well-known/oauth-protected-resource, and POST /oauth/register are mounted
# alongside the existing static-bearer path. Required for claude.ai custom
# connector registration / Claude mobile. Must be the externally reachable URL
# (https, or http://localhost|127.0.0.1 for local dev), with no trailing slash.
# WALDO_PUBLIC_URL=https://waldo-nas.your-tailnet.ts.net

# Optional (slice 2+ — wired in slice 1 but only enforced once the consent
# page lands): single admin password gating GET /oauth/authorize. Generate
# with: openssl rand -hex 24
# WALDO_ADMIN_PASSWORD=

# Optional: when true, refuses static-bearer auth on the MCP endpoint and
# requires an OAuth access token. Defaults to false so Claude Desktop's
# bearer-token config keeps working. Flip to true once mobile/claude.ai is
# the primary access path. (Effective from slice 4 onward.)
# WALDO_DISABLE_STATIC_BEARER=true
